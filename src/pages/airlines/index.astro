---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const airlines = await getCollection('airlines');

type Airline = CollectionEntry<'airlines'>['data'];

function signature(a: Airline) {
  return `${a.dimsCm.join(',')}_${a.carryOnWeightKg}_${a.freeCarryOn}`;
}

const groupMap = new Map<string, Airline[]>();
for (const { data } of airlines) {
  const key = signature(data);
  const list = groupMap.get(key) ?? [];
  list.push(data);
  groupMap.set(key, list);
}

function riskScore(a: Airline) {
  const weightPenalty = 10 - a.carryOnWeightKg;
  return a.freeCarryOn ? weightPenalty : 999;
}

const sortedGroups = Array.from(groupMap.values()).sort((a, b) => {
  const scoreDiff = riskScore(a[0]) - riskScore(b[0]);
  if (scoreDiff !== 0) return scoreDiff;
  return b[0].dimsCm[1] - a[0].dimsCm[1];
});

// 템플릿 안에서 비교 연산자를 직접 쓰면 Astro 파서가 태그 시작으로 오인하는 경우가 있어,
// 표시에 필요한 값은 전부 여기서 미리 계산해둔다.
const rows = sortedGroups.map((members) => {
  const rep = members[0];
  const isRisky = rep.carryOnWeightKg <= 7 || rep.freeCarryOn === false;
  const types = [...new Set(members.map((m) => m.type))].join(' / ');
  const trap = members.find((m) => m.trapNote)?.trapNote ?? '-';
  const dimsLabel = `${rep.dimsCm[0]}×${rep.dimsCm[1]}×${rep.dimsCm[2]}cm`;
  const weightLabel = rep.freeCarryOn ? `${rep.carryOnWeightKg}kg` : '무료 반입 불가';
  const names = members.map((m) => ({
    name: m.name,
    sourceUrl: m.sourceUrl,
    note: m.weightNote ?? null,
  }));
  return { isRisky, types, trap, dimsLabel, weightLabel, names };
});

const lastVerified = airlines
  .map((a) => a.data.lastVerified)
  .sort((a, b) => b.valueOf() - a.valueOf())[0]
  .toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="항공사별 기내 수하물 규정 비교" description="국내·해외 항공사 기내 휴대 수하물 크기·무게 규정을 규정이 같은 항공사끼리 묶어서 비교합니다.">
  <article>
    <p class="article-meta">규정 데이터 · 최종 확인 {lastVerified}</p>
    <h1>항공사별 기내 수하물 규정 비교</h1>
    <p>총 {airlines.length}개 항공사를 조사해, <strong>같은 규정을 쓰는 항공사는 한 행으로 묶고</strong> 실제로 다른 규정끼리만 구분했습니다. 국내 항공사끼리는 규정이 대부분 비슷하지만(세 변의 합 115cm, 10kg), 해외 저가항공사로 갈수록 크기·무게·심지어 "무료 여부"까지 달라집니다.</p>

    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>항공사</th>
            <th>유형</th>
            <th>기내 수하물 크기</th>
            <th>무게 제한</th>
            <th>비고</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class={row.isRisky ? 'row-warning' : ''}>
              <td>
                {row.names.map((n, i) => (
                  <Fragment>
                    {i > 0 ? ' · ' : ''}
                    <a href={n.sourceUrl} target="_blank" rel="noopener">{n.name}</a>
                    {n.note ? <span class="cell-note"> ({n.note})</span> : null}
                  </Fragment>
                ))}
              </td>
              <td>{row.types}</td>
              <td>{row.dimsLabel}</td>
              <td>{row.weightLabel}{row.isRisky ? ' ⚠️' : ''}</td>
              <td>{row.trap}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="disclaimer">항공사 수하물 규정은 예고 없이 변경될 수 있습니다. 실제 탑승 전 반드시 해당 항공사 공식 페이지(표의 항공사명 링크)에서 최신 규정을 다시 확인하세요. 위 데이터 중 대한항공·아시아나항공·티웨이항공은 공식 페이지 접속이 제한되어 2차 출처(비교 정리 페이지)로 교차 확인했습니다.</p>
  </article>
</Layout>
